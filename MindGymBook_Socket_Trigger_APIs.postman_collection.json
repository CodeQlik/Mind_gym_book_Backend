{
  "info": {
    "name": "Mind Gym Book - Socket.IO Trigger APIs",
    "_postman_id": "mindgymbook-socket-trigger-collection",
    "description": "This collection contains all API endpoints that trigger real-time Socket.IO notifications.\n\n### How to test:\n1. Connect to Socket.IO server on: `ws://localhost:5000` (or your backend URL)\n2. Emit `join` event with your `userId` to join your private room.\n3. Call these APIs and listen for the `notification` event on the client side.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "https://mindgymbook.ductfabrication.in/api/v1", "type": "string" },
    { "key": "token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "🚀 Manual Admin Notifications",
      "item": [
        {
          "name": "Send Notification (Custom Target)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/notifications/admin/send",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"target\": \"USER\",\n  \"user_id\": 1,\n  \"type\": \"CUSTOM\",\n  \"title\": \"Hello User!\",\n  \"message\": \"This is a real-time socket notification test.\",\n  \"send_push\": true,\n  \"send_email\": false\n}"
            }
          }
        },
        {
          "name": "Send Broadcast (All Users)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/notifications/admin/send",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"target\": \"ALL\",\n  \"type\": \"BROADCAST\",\n  \"title\": \"Server Maintenance\",\n  \"message\": \"Server will be down for 10 minutes tonight.\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "📦 Order & Payment Triggers",
      "item": [
        {
          "name": "Create Order (Triggers ORDER_CREATED)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/orders",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"address_id\": 1,\n  \"payment_method\": \"prepaid\"\n}"
            }
          }
        },
        {
          "name": "Verify Payment (Triggers ORDER_PAID / SUBSCRIPTION_ACTIVATED)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/payments/verify",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"razorpay_order_id\": \"razorpay_order_id_here\",\n  \"razorpay_payment_id\": \"razorpay_payment_id_here\",\n  \"razorpay_signature\": \"test_signature\"\n}"
            }
          }
        },
        {
          "name": "Cancel Order (Triggers ORDER_CANCELLED)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/orders/cancel/1"
          }
        },
        {
          "name": "Request Refund (Triggers REFUND_REQUEST)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/orders/refund/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Item quality not as expected\"\n}"
            }
          }
        },
        {
          "name": "Dispatch Order (Triggers ORDER_SHIPPED)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/orders/admin/dispatch/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tracking_id\": \"TRK123456789\",\n  \"courier_name\": \"BlueDart\"\n}"
            }
          }
        },
        {
          "name": "Update Order Status (Triggers ORDER_STATUS_UPDATE)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/orders/admin/update-status/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"delivery_status\": \"delivered\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "� Book & Content Triggers",
      "item": [
        {
          "name": "Create Book (Triggers NEW_BOOK_RELEASE Broadcast)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/book",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Realtime Socket Test Book", "type": "text" },
                { "key": "author", "value": "Agent Antigravity", "type": "text" },
                { "key": "price", "value": "499", "type": "text" },
                { "key": "category_id", "value": "1", "type": "text" },
                { "key": "description", "value": "This book release will trigger a broadcast socket notification.", "type": "text" },
                { "key": "book_file", "value": "", "type": "file" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "�💎 Subscription Triggers",
      "item": [
        {
          "name": "Update Subscription Status (Triggers SUBSCRIPTION_ACTIVATED)",
          "description": "Used to manually activate/deactivate a subscription. Set status to 'active' to trigger notification.",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/subscriptions/admin/status/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"active\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "👤 User Triggers",
      "item": [
        {
          "name": "Register User (Triggers WELCOME)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/users/register",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Socket Test User", "type": "text" },
                { "key": "email", "value": "socket-test-1@example.com", "type": "text" },
                { "key": "password", "value": "Password@123", "type": "text" },
                { "key": "phone", "value": "9876543210", "type": "text" },
                { "key": "device_id", "value": "DEVICE-ID-SOCKET-TEST", "type": "text" },
                { "key": "verificationToken", "value": "PASTE_TOKEN_HERE", "type": "text" }
              ]
            }
          }
        }
      ]
    }
  ]
}
